#!/bin/bash

BRANCH=$(git rev-parse --abbrev-ref HEAD)

# Skip structural validation on gh-pages
if [ "$BRANCH" = "gh-pages" ]; then
    echo "=== Pre-push: Skipping structural validation on gh-pages ==="
    exit 0
fi

echo "=== Pre-push: Structural Validation ==="

python tools/super_doctor.py --dry-run
STATUS=$?

if [ $STATUS -ne 0 ]; then
    echo "❌ Structural violations detected by SuperDoctor."
    echo "Push blocked."
    exit 1
fi

echo "✔ Structure clean. Push allowed."
exit 0
